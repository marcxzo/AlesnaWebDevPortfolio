---

---
<div class="hero container">
  <div class="heroBackground">
    <h1>Hi, I'm <strong>Marco</strong></h1>
    <div class="hero_BtnWrapper">
      <button class="btn1">View my Work</button>
      <button class="btn2">Work with me</button>
    </div>
  </div>
</div>
<style>
  .heroBackground{
    padding-top: 5em;
    /* background: url('../images/citybackground.webp'); */
    height: 100%;
    margin: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-left: var(--size-base);
    padding-right: var(--size-base);
  }
  h1{
    font-size: var(--size-5xl);
  }
  .hero {
    height: 80vh;
    display: flex;
    gap: 1em;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }
  .hero_BtnWrapper {
    display: flex;
    flex-direction: column;
    padding-top: .5em;
    gap: 1em;
  }
  button{
    padding: var(--size-base);
    font-size: var(--size-base);
    font-weight: 600;
    background-color: transparent;
    border: none;
    border-radius: 1.75em;
    /* text-transform: uppercase; */
  }
  .btn1 {
    border: 2px solid var(--clr-dark);
  }
  .btn1:hover{
    color: var(--clr-light);
    /* text-transform: uppercase; */
    background-color: var(--clr-dark);
    transition: all .2s ease-in;
  }
  .btn2 {
    color: var(--clr-crimson);
    background-color: transparent;
    border: 2px solid var(--clr-crimson);
  }
  .btn2:hover {
    color: var(--clr-light);
    /* text-transform: uppercase; */
    background-color: var(--clr-crimson);
    border: 2px solid var(--clr-crimson);
    transition: all .2s ease-in;
  }
  /* xs */
  /* @media (min-width: 475px) {} */

  /* sm */
  @media (min-width: 640px) {
    .hero_BtnWrapper {
      flex-direction: row;
    }
  }

  /* md */
  /* @media (min-width: 768px) {} */

  /* lg */
  /* @media (min-width: 1024px) {} */

  /* xl */
  /* @media (min-width: 1280px) {} */

  /* 2xl */
  /* @media (min-width: 1536px) {} */
</style>